// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Core user model. Password is nullable to support future OAuth providers.
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String?  // Nullable for future OAuth support
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  accounts Account[]

  @@map("users")
}

/// Account model for OAuth providers (future use).
/// Allows linking multiple auth providers to a single user.
model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  provider          String  // e.g., "credentials", "discord", "google"
  providerAccountId String  @map("provider_account_id")
  refreshToken      String? @map("refresh_token")
  accessToken       String? @map("access_token")
  expiresAt         Int?    @map("expires_at")
  tokenType         String? @map("token_type")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}
