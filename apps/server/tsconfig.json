{
    "extends": "@blueprint/typescript-config/server.json",
    "compilerOptions": {
        "outDir": "./dist",
        "baseUrl": ".",
        "types": [
            "bun-types"
        ],
        "paths": {
            "@/*": [
                "./src/*"
            ]
        }
    },
    "include": [
        "src/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}