{
    "name": "@blueprint/server",
    "version": "0.0.0",
    "private": true,
    "scripts": {
        "dev": "bun run --watch src/index.ts",
        "build": "bun build src/index.ts --outdir ./dist --target bun",
        "start": "bun run dist/index.js",
        "type-check": "tsc --noEmit"
    },
    "dependencies": {
        "@blueprint/db": "workspace:*",
        "@blueprint/shared": "workspace:*",
        "@elysiajs/cors": "^1.2.0",
        "@elysiajs/jwt": "^1.2.0",
        "elysia": "^1.2.0",
        "jose": "^6.1.3"
    },
    "devDependencies": {
        "@blueprint/typescript-config": "workspace:*",
        "@types/bun": "latest",
        "bun-types": "^1.3.10",
        "typescript": "^5.7.0"
    }
}